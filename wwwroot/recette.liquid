---
layout: index.liquid
pagination:
    data: allrecettes
    size: 1
    alias: recette
    addAllPagesToCollections: true
permalink: "recettes/{% if recette.slug %}{{ recette.slug }}{% else %}{{ recette.title | slugify }}{% endif %}/"
eleventyComputed:
    title: "{{recette.title}} - Anne et ses Délices"
    description: "Découvrez la recette {{ recette.title }} sur Anne et ses Délices."
    meta:
        og:type: "recipe"
        og:title: "{{recette.title}} - Anne et ses Délices"
        og:description: "Découvrez la recette {{ recette.title }} sur Anne et ses Délices."
        og:image: "{{recette.cover | default: '/assets/logo.svg'}}"
        og:url: "https://anneetsesdelices.fr{{ page.url }}"
tags:
    - recettes
---

        <script type="application/ld+json">{
            "@context": "https://schema.org",
            "@type": "Recipe",
            "name": {{ recette.title | jsonify }},
            "image": {{ recette.cover | default: '/assets/logo.svg' | jsonify }},
            "description": {{ recette.description | default: recette.intro | default: '' | jsonify }},
            "author": {"@type": "Person", "name": "Anne Penin"},
            "recipeIngredient": {{ recette.toppings | map: 'name' | jsonify }},
            "recipeInstructions": {{ recette.steps | jsonify }},
            "prepTime": {{ recette.preptime | default: '' | jsonify }},
            "cookTime": {{ recette.cooktime | default: '' | jsonify }},
            "totalTime": {{ recette.totaltime | default: '' | jsonify }},
            "recipeYield": {{ recette.for | default: '' | jsonify }}
        }</script>

        <header>
        {% if recette.cover %}
            <img class="backdrop-cover" src="{{recette.cover}}" />
            <img class="panel cover" src="{{recette.cover}}" />
        {% endif %}
        <h1 class="panel">{{recette.title}}</h1>
    </header>
    <div class="info panel">
        <div>
            <span class="count fal fa-utensils"></i>{{recette.for}}</span>
            <span class="preptime fal fa-hat-chef">{{recette.preptime}}</span>
            <span class="resttime fal fa-snooze">{{recette.resttime}}</span>
            <span class="cooktime fal fa-oven">{{recette.cooktime}}</span>
        </div>
        <div class="mold">
            <a href="{{recette.mold.url ?? '#'}}?s=AnneetsesDelices">
                <img src="{{recette.mold.picture}}" />
                <span class="name">{{recette.mold.name}}</span>
            </a>
        </div>
    </div>
    {% if recette.accessories.length %}
    <div class="accessories panel">
        <h2>Accessoires</h2>
        <ul>
            {%- for accessory in recette.accessories %}
                <li class="mold">
                    <a href="{{accessory.url}}?s=AnneetsesDelices">
                        <img src="{{accessory.picture}}" />
                        <span class="name">{{accessory.name}}</span>
                    </a>
                </li>
            {% endfor -%}    
        </ul>
    </div>
        {% endif %}
    <div class="toppings panel">
        <h2>Ingrédients</h2>
        <ul>
        {%- if recette.categorizedToppings[''] %}
            {%- for topping in recette.categorizedToppings[''] %}
                <li>{{ topping.quantity }} {{ topping.unit }} {{ topping.name }}</li>
            {% endfor -%}
        {%- else %}
            {%- for category in recette.categorizedToppings %}
                <li><h3>{{ category[0] }}</h3>
                    <ul>
                    {%- for topping in category[1] %}
                        <li>{{ topping.quantity }} {{ topping.unit }} {{ topping.name }}</li>
                    {% endfor -%}
                    </ul>
                </li>
            {% endfor -%}
        {% endif -%}
        </ul>
    </div>
    <div class="steps panel">
        <h2>Préparation</h2>
        {{recette.formattedSteps}}
        {% if recette.gallery and recette.gallery.length %}
        <div class="gallery">
            <h3>Galerie</h3>
            <div class="gallery-grid">
                {%- for photo in recette.gallery %}
                    <img src="{{photo}}" alt="Photo de la recette" loading="lazy" />
                {% endfor -%}
            </div>
        </div>
        {% endif %}
        <p style="padding-left:24px"><a
                href="https://www.guydemarle.com/profil/annep_a143-44563">Anne Penin</a>, votre conseillère Guy Demarle</p>
    </div>
    <div class="logo">
        <img class="qr" src="{{relativePath}}/assets/qr_code.svg" style="height:100%" />
        <span class="ad">Retrouvez-moi sur facebook </span>
        <a href="https://www.facebook.com/profile.php?id=100090744024852">
            <img src="{{relativePath}}/assets/logo.svg" style="height:100%" />
        </a>
    </div>
